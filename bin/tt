#!/usr/bin/env node

// tt - Terminal Board CLI
// Inter-terminal communication tool for use within terminal-board sessions.
// Environment: TBOARD_SOCKET (unix socket path, preferred), TBOARD_URL (server URL), TBOARD_SESSION (own session ID)

import { readFileSync, existsSync } from 'fs';
import http from 'http';

let BASE = process.env.TBOARD_URL || '';
const SOCKET_PATH = process.env.TBOARD_SOCKET || '';
const SELF = process.env.TBOARD_SESSION || '';
const TOKEN = process.env.TBOARD_TOKEN || '';

// Unix socket fetch: uses http.request with socketPath
function socketFetch(path, options = {}) {
  return new Promise((resolve, reject) => {
    const method = options.method || 'GET';
    const body = options.body || null;
    const req = http.request({
      socketPath: SOCKET_PATH,
      path,
      method,
      headers: options.headers || {},
    }, (res) => {
      let data = '';
      res.on('data', chunk => data += chunk);
      res.on('end', () => {
        resolve({
          ok: res.statusCode >= 200 && res.statusCode < 300,
          status: res.statusCode,
          json: () => Promise.resolve(JSON.parse(data)),
          text: () => Promise.resolve(data),
        });
      });
    });
    req.on('error', reject);
    if (options.signal) {
      options.signal.addEventListener('abort', () => {
        req.destroy();
        reject(new Error('aborted'));
      });
    }
    if (body) req.write(body);
    req.end();
  });
}

// Unified fetch: try Unix socket first, fall back to HTTP on connection error
// (e.g. PowerShell on Windows cannot access WSL Unix sockets)
let socketFailed = false;
async function ttFetch(urlOrPath, options = {}) {
  if (SOCKET_PATH && !socketFailed) {
    const path = urlOrPath.startsWith('http') ? new URL(urlOrPath).pathname + (new URL(urlOrPath).search || '') : urlOrPath;
    try {
      return await socketFetch(path, options);
    } catch (err) {
      // Socket unreachable (EPERM, ENOENT, ECONNREFUSED) — fall back to HTTP
      socketFailed = true;
    }
  }
  // HTTP fallback: ensure BASE is set
  if (!BASE) await detectBase();
  const url = urlOrPath.startsWith('http') ? urlOrPath : `${BASE}${urlOrPath}`;
  return fetch(url, options);
}

// Auto-detect server URL if not set (scan common ports)
async function detectBase() {
  if (SOCKET_PATH || BASE) return;
  // Check PORT env as explicit override
  if (process.env.PORT) {
    BASE = `http://127.0.0.1:${process.env.PORT}`;
    return;
  }
  // Try default port first, then scan dev server range
  const candidates = [3001];
  for (let p = 51700; p <= 51800; p++) candidates.push(p);
  for (const port of candidates) {
    try {
      const res = await fetch(`http://127.0.0.1:${port}/api/terminals/status`, { signal: AbortSignal.timeout(200) });
      if (res.ok) {
        const data = await res.json();
        if (data.statuses) {
          BASE = `http://127.0.0.1:${port}`;
          return;
        }
      }
    } catch {}
  }
  BASE = 'http://127.0.0.1:3001';
}

async function main() {
  await detectBase();
  const [,, cmd, ...args] = process.argv;

  switch (cmd) {
    case 'ls':
    case 'list':
      return listTerminals();
    case 'send':
    case 'write':
      return sendCommand(args);
    case 'read':
    case 'output':
      return readOutput(args[0], ...args.slice(1));
    case 'name':
      return setName(args[0], args[1]);
    case 'ipc':
      return ipcSendAndWait(args);
    case 'history':
      return showHistory(args[0]);
    case 'last':
      return readLast(args[0], ...args.slice(1));
    case 'poll':
      return pollResponse(args[0], args[1]);
    case 'peers':
      return listPeers();
    case 'peer':
      return peerCommand(args);
    case 'self':
      return showSelf();
    case 'status':
      return showStatus(args[0]);
    case 'notify':
      return sendNotification(args);
    case 'notifications':
      return showNotifications(...args);
    case 'tasks':
      return showTasks(args[0]);
    case 'task':
      return taskCommand(args);
    case 'link':
      return linkReconnect(args);
    case 'mcp-stdio':
      return mcpStdioServer();
    default:
      printHelp();
  }
}

async function listTerminals() {
  const res = await ttFetch(`${BASE}/api/terminals/status`);
  const { statuses } = await res.json();

  if (statuses.length === 0) {
    console.log('No active terminals.');
    return;
  }

  // Fetch peers for current session
  let peerIds = new Set();
  if (SELF) {
    try {
      const peerRes = await ttFetch(`${BASE}/api/links/peers/${SELF}`);
      const peerData = await peerRes.json();
      peerIds = new Set((peerData.peers || []).map((p) => p.sessionId));
    } catch {}
  }

  // Header
  console.log(pad('ID', 10) + pad('NAME', 12) + pad('PROCESS', 14) + 'CWD');
  console.log('-'.repeat(60));

  for (const s of statuses) {
    const shortId = s.sessionId.slice(0, 8);
    const isSelf = s.sessionId === SELF;
    const isPeer = peerIds.has(s.sessionId);
    const marker = isSelf ? '*' : isPeer ? '+' : ' ';
    const name = s.name || '-';
    const proc = s.foregroundProcess || 'shell';
    console.log(
      marker + pad(shortId, 9) + pad(name, 12) + pad(proc, 14) + (s.cwdShort || s.cwd)
    );
  }

  if (SELF) {
    console.log(`\n* = this terminal` + (peerIds.size > 0 ? ', + = linked peer' : ''));
  }
}

async function sendCommand(args) {
  if (args.length < 2) {
    console.error('Usage: tt send <id|name> [--file <path>] <command...>');
    process.exit(1);
  }

  const target = args[0];
  let noNewline = false;
  let commandArgs = args.slice(1);

  if (commandArgs[0] === '--raw') {
    noNewline = true;
    commandArgs = commandArgs.slice(1);
  }

  let command;
  const fileIdx = commandArgs.indexOf('--file');
  if (fileIdx !== -1) {
    const filePath = commandArgs[fileIdx + 1];
    if (!filePath) {
      console.error('Error: --file requires a path argument.');
      process.exit(1);
    }
    if (!existsSync(filePath)) {
      console.error(`Error: File not found: ${filePath}`);
      process.exit(1);
    }
    command = readFileSync(filePath, 'utf-8').trimEnd();
  } else {
    command = commandArgs.join(' ');
  }

  // Routing (Phase 2a):
  //   --raw → direct terminal write (no newline, no task/IPC framing)
  //   normal → POST /api/tasks/send (primary task dispatch path; no IPC marker)
  // Legacy fallback: if the server predates Phase 2a and returns 404 for
  // /api/tasks/send, retry against /api/ipc/send so a running Phase-0/1 server
  // still works. `tt ipc` / `tt peer ipc` (legacy round-trip) always uses
  // /api/ipc/send via ipcSendAndWait() and does NOT register a task.
  const body = noNewline
    ? JSON.stringify({ data: command, sourceSessionId: SELF || undefined })
    : JSON.stringify({ target, message: command, sourceSessionId: SELF || undefined });

  let url;
  if (noNewline) {
    url = `${BASE}/api/terminals/${encodeURIComponent(target)}/write`;
  } else {
    url = `${BASE}/api/tasks/send`;
  }

  let res = await ttFetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body,
  });

  // Legacy server fallback (pre-Phase-2a). An old server either 404s on
  // /api/tasks/send or — more commonly — lets the SPA catch-all answer 200
  // with index.html. Detect both by reading the body as text and checking
  // for HTML when JSON.parse fails. This works on both fetch and socketFetch
  // (which does not expose response headers).
  let bodyText = await res.text();
  let parsed;
  try {
    parsed = JSON.parse(bodyText);
  } catch {
    parsed = null;
  }
  const looksLikeHtml = !parsed && bodyText.trimStart().startsWith('<');
  if (!noNewline && (res.status === 404 || looksLikeHtml)) {
    res = await ttFetch(`${BASE}/api/ipc/send`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body,
    });
    bodyText = await res.text();
    try { parsed = JSON.parse(bodyText); } catch { parsed = null; }
  }
  const result = parsed || { error: `Non-JSON response (status=${res.status}): ${bodyText.slice(0, 200)}` };
  if (result.error) {
    console.error(`Error: ${result.error}`);
    process.exit(1);
  }
  if (result.taskId) {
    console.log(`Sent to ${target} (task=${result.taskId}).`);
  } else {
    console.log(`Sent to ${target}.`);
  }
}

async function readOutput(target, ...extraArgs) {
  if (!target) {
    console.error('Usage: tt read <id|name> [lines] [--since-send] [--all] [--full] [--wait] [--buffer]');
    process.exit(1);
  }

  // Parse flags
  let lines = 100;
  let wait = false;
  let timeout = 0; // 0 = no timeout (hidden --timeout=N still accepted)
  let useBuffer = false;
  let sinceSend = false;
  let all = false;
  let full = false;

  for (const arg of extraArgs) {
    if (arg === undefined) continue;
    const timeoutMatch = String(arg).match(/^--timeout=(\d+)$/);
    if (timeoutMatch) { timeout = parseInt(timeoutMatch[1]); continue; }
    if (arg === '--wait') { wait = true; continue; }
    if (arg === '--buffer') { useBuffer = true; continue; }
    if (arg === '--since-send') { sinceSend = true; continue; }
    if (arg === '--all') { all = true; continue; }
    if (arg === '--full') { full = true; continue; }
    const parsed = parseInt(arg);
    if (!isNaN(parsed)) { lines = parsed; continue; }
  }

  const enc = encodeURIComponent(target);

  // Build query string based on flags.
  // Note: the `sinceSend=true` rendered-buffer path uses legacy `[ipc:...]`
  // marker grep plus hard-coded noise stripping (stripAgentNoise). It is
  // best-effort only and is preserved for compatibility / true debug use.
  // Phase 2b: when a task exists between SELF and target, `--since-send`
  // falls through to the task capture below first.
  const buildRenderedUrl = () => {
    if (sinceSend) return `${BASE}/api/terminals/${enc}/rendered?sinceSend=true&clean=true`;
    if (all) return `${BASE}/api/terminals/${enc}/rendered?clean=true`;
    return `${BASE}/api/terminals/${enc}/rendered?lines=${lines}&clean=true`;
  };

  // Try to read the latest task capture between SELF and target. Returns a
  // discriminated result so callers can distinguish "no task exists here"
  // (legitimate fallback to legacy rendered-buffer path) from "something
  // actually broke" (should be surfaced, not silently masked).
  //
  // Server returns 404 with a typed `code` field:
  //   code=no-task          → genuine absence of a task (legitimate fallback)
  //   code=session-not-found → source or target cannot resolve (real error)
  //   code=capture-missing   → task exists but capture file is gone (real error)
  //
  // Result shape:
  //   { kind: 'ok', capture }        — authoritative task capture
  //   { kind: 'no-task' }            — only the no-task 404 code
  //   { kind: 'no-self' }            — not running inside a tboard session
  //   { kind: 'error', message }     — everything else; do NOT fall through
  const tryLatestTaskCapture = async () => {
    if (!SELF) return { kind: 'no-self' };
    let res;
    try {
      res = await ttFetch(`${BASE}/api/captures/latest/${encodeURIComponent(SELF)}/${enc}`);
    } catch (e) {
      return { kind: 'error', message: (e && e.message) || String(e) };
    }
    let body;
    try { body = await res.json(); } catch { body = null; }
    if (res.status === 404) {
      if (body && body.code === 'no-task') return { kind: 'no-task' };
      const detail = body && (body.error || body.code) ? `${body.code || ''} ${body.error || ''}`.trim() : 'HTTP 404';
      return { kind: 'error', message: detail };
    }
    if (!res.ok) return { kind: 'error', message: `HTTP ${res.status}` };
    if (!body) return { kind: 'error', message: 'JSON parse failed' };
    if (body.error) return { kind: 'error', message: body.error };
    return { kind: 'ok', capture: body };
  };

  // Mode: wait for completion then read.
  // Polling uses the rendered buffer's `isProcessing` signal (independent of
  // task lifecycle). After the poll settles, if the caller asked for a
  // task-scoped view (--since-send or --full), read the authoritative task
  // capture instead of leaving the last rendered snapshot as the result.
  if (wait) {
    let settled = 0;
    let lastOutput = '';
    const deadline = timeout > 0 ? Date.now() + timeout * 1000 : 0;
    while (true) {
      if (deadline > 0 && Date.now() >= deadline) break;
      const res = await ttFetch(buildRenderedUrl());
      const result = await res.json();
      if (result.error) { console.error(`Error: ${result.error}`); process.exit(1); }
      lastOutput = result.output || '';
      if (!result.isProcessing) {
        settled++;
        if (settled >= 3) break;
      } else {
        settled = 0;
      }
      await new Promise(r => setTimeout(r, 2000));
    }
    // After the agent settles, prefer the task capture when a task exists
    // and the caller asked for a task-oriented view. Error surfacing is
    // symmetric across --full and --since-send: any genuine capture read
    // failure (transport, server-error, missing capture) exits non-zero.
    // Only `no-task` / `no-self` keeps the rendered snapshot as a
    // best-effort legacy fallback (matching the non-wait behavior).
    if (full || sinceSend) {
      const attempt = await tryLatestTaskCapture();
      if (attempt.kind === 'ok') {
        lastOutput = attempt.capture.output || '';
        if (attempt.capture.truncated) process.stderr.write('(capture was truncated at 50MB limit)\n');
      } else if (attempt.kind === 'error') {
        console.error(`Error reading task capture: ${attempt.message}`);
        process.exit(1);
      }
    }
    process.stdout.write(lastOutput);
    if (lastOutput && !lastOutput.endsWith('\n')) process.stdout.write('\n');
    return;
  }

  // Mode: full task capture from disk (no buffer limit).
  // Like --since-send, distinguish "no task" (legitimate fallback) from
  // "capture read failed" (surface the error).
  if (full) {
    const attempt = await tryLatestTaskCapture();
    if (attempt.kind === 'ok') {
      const cap = attempt.capture;
      process.stdout.write(cap.output || '');
      if (cap.output && !cap.output.endsWith('\n')) process.stdout.write('\n');
      if (cap.truncated) process.stderr.write('(capture was truncated at 50MB limit)\n');
      if (cap.status === 'pending') process.stderr.write('(task still in progress -- capture may be incomplete)\n');
      else if (cap.status === 'draining') process.stderr.write('(task completed but capture is still recording final output)\n');
      return;
    }
    if (attempt.kind === 'error') {
      console.error(`Error reading task capture: ${attempt.message}`);
      process.exit(1);
    }
    // kind === 'no-task' or 'no-self' → fall back to rendered output.
    process.stderr.write('No capture available, falling back to rendered output.\n');
    const fallbackRes = await ttFetch(buildRenderedUrl());
    const fallbackResult = await fallbackRes.json();
    if (fallbackResult.error) { console.error(`Error: ${fallbackResult.error}`); process.exit(1); }
    process.stdout.write(fallbackResult.output || '');
    if (fallbackResult.output && !fallbackResult.output.endsWith('\n')) process.stdout.write('\n');
    return;
  }

  // Mode: legacy buffer (escape hatch)
  if (useBuffer) {
    const res = await ttFetch(`${BASE}/api/terminals/${enc}/buffer?lines=${lines}`);
    const result = await res.json();
    if (result.error) { console.error(`Error: ${result.error}`); process.exit(1); }
    process.stdout.write(result.output || '');
    if (result.output && !result.output.endsWith('\n')) process.stdout.write('\n');
    return;
  }

  // Phase 2b: --since-send prefers the latest task capture over the rendered
  // buffer marker-grep. Capture is authoritative (no heuristics, no spinner
  // noise), matches what `tt task report` / `tt task manifest` describe, and
  // contains everything the SUB produced during the task. Fall back to the
  // legacy rendered path only when we can prove there is no task to anchor on.
  // Transient errors surface instead of being masked as stale rendered output.
  if (sinceSend) {
    const attempt = await tryLatestTaskCapture();
    if (attempt.kind === 'ok') {
      const cap = attempt.capture;
      process.stdout.write(cap.output || '');
      if (cap.output && !cap.output.endsWith('\n')) process.stdout.write('\n');
      if (cap.truncated) process.stderr.write('(capture was truncated at 50MB limit)\n');
      if (cap.status === 'pending') process.stderr.write('(task still in progress -- capture may be incomplete)\n');
      else if (cap.status === 'draining') process.stderr.write('(task completed but capture is still recording final output)\n');
      return;
    }
    if (attempt.kind === 'error') {
      console.error(`Error reading task capture: ${attempt.message}`);
      process.exit(1);
    }
    // kind === 'no-task' or 'no-self' → fall through to rendered-buffer
    // marker-grep (debug-only path). This is the only legitimate fallback.
  }

  // Default: rendered output (clean, noise-stripped).
  // When --since-send reaches here, it is the best-effort legacy path; the
  // task-based preferred path is above.
  const res = await ttFetch(buildRenderedUrl());
  const result = await res.json();
  if (result.error) { console.error(`Error: ${result.error}`); process.exit(1); }
  process.stdout.write(result.output || '');
  if (result.output && !result.output.endsWith('\n')) process.stdout.write('\n');
  if (result.isProcessing) {
    process.stderr.write('(still processing...)\n');
  }
}

async function ipcSendAndWait(args) {
  if (args.length < 2) {
    console.error('Usage: tt ipc <id|name> <message...>');
    process.exit(1);
  }

  const target = args[0];
  let timeout = 0; // 0 = no timeout
  const msgParts = [];
  for (const a of args.slice(1)) {
    const m = a.match(/^--timeout=(\d+)$/);
    if (m) { timeout = parseInt(m[1]); } else { msgParts.push(a); }
  }
  const message = msgParts.join(' ');

  // Send via IPC endpoint with sourceSessionId for history tracking
  const sendRes = await ttFetch(`${BASE}/api/ipc/send`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ target, message, sourceSessionId: SELF || undefined }),
  });
  const sendResult = await sendRes.json();
  if (sendResult.error) {
    console.error(`Send error: ${sendResult.error}`);
    process.exit(1);
  }

  const sessionId = sendResult.sessionId;
  const turnId = sendResult.turnId;
  const encodedMsg = encodeURIComponent(message);
  const encodedTurnId = turnId ? `&turnId=${encodeURIComponent(turnId)}` : '';
  const deadline = timeout > 0 ? Date.now() + timeout * 1000 : 0;

  process.stderr.write(`Sent to ${target}. Waiting for response...\n`);

  // Poll until processing stops and we have output
  let settled = 0;
  let lastOutput = '';
  while (true) {
    if (deadline > 0 && Date.now() >= deadline) break;
    await sleep(1500);
    const pollRes = await ttFetch(
      `${BASE}/api/ipc/response/${sessionId}?message=${encodedMsg}${encodedTurnId}`
    );
    const poll = await pollRes.json();
    lastOutput = poll.output || '';

    if (poll.timedOut) {
      process.stderr.write('Error: IPC turn timed out (no response within 10 minutes).\n');
      process.exit(1);
    }

    if (!poll.isProcessing) {
      settled++;
      if (settled >= 2) break;
    } else {
      settled = 0;
    }
  }

  process.stdout.write(lastOutput);
  if (!lastOutput.endsWith('\n')) {
    process.stdout.write('\n');
  }
}

async function pollResponse(target, messageArg) {
  if (!target || !messageArg) {
    console.error('Usage: tt poll <id|name> <message>');
    process.exit(1);
  }
  const encodedMsg = encodeURIComponent(messageArg);
  const res = await ttFetch(
    `${BASE}/api/ipc/response/${encodeURIComponent(target)}?message=${encodedMsg}`
  );
  const result = await res.json();
  if (result.error) {
    console.error(`Error: ${result.error}`);
    process.exit(1);
  }
  process.stdout.write(result.output || '');
  if (result.output && !result.output.endsWith('\n')) {
    process.stdout.write('\n');
  }
  process.stderr.write(`processing=${result.isProcessing}\n`);
}

async function readLast(target, ...extraArgs) {
  if (!target) {
    console.error('Usage: tt last <id|name> [--wait]');
    process.exit(1);
  }

  const wait = extraArgs.includes('--wait');
  const enc = encodeURIComponent(target);

  // --wait: poll until agent finishes, then return last response
  if (wait) {
    let settled = 0;
    let lastResult = null;
    while (true) {
      const res = await ttFetch(`${BASE}/api/ipc/last/${enc}`);
      lastResult = await res.json();
      if (lastResult.error) { console.error(`Error: ${lastResult.error}`); process.exit(1); }
      if (!lastResult.isProcessing) {
        settled++;
        if (settled >= 3) break;
      } else {
        settled = 0;
      }
      await sleep(2000);
    }
    if (lastResult.prompt) {
      process.stderr.write(`prompt: ${lastResult.prompt}\n`);
    }
    process.stdout.write(lastResult.output || '(no response)');
    if (lastResult.output && !lastResult.output.endsWith('\n')) {
      process.stdout.write('\n');
    }
    return;
  }

  // Default: immediate read
  const res = await ttFetch(`${BASE}/api/ipc/last/${enc}`);
  const result = await res.json();
  if (result.error) {
    console.error(`Error: ${result.error}`);
    process.exit(1);
  }
  if (result.prompt) {
    process.stderr.write(`prompt: ${result.prompt}\n`);
  }
  process.stdout.write(result.output || '(no response yet)');
  if (result.output && !result.output.endsWith('\n')) {
    process.stdout.write('\n');
  }
  if (result.isProcessing) {
    process.stderr.write('(still processing...)\n');
  }
}

async function showHistory(target) {
  if (!target) {
    console.error('Usage: tt history <id|name>');
    process.exit(1);
  }

  const res = await ttFetch(
    `${BASE}/api/ipc/history/${encodeURIComponent(target)}`
  );
  const result = await res.json();
  if (result.error) {
    console.error(`Error: ${result.error}`);
    process.exit(1);
  }

  const entries = result.entries || [];
  if (entries.length === 0) {
    console.log('No IPC history for this session.');
    return;
  }

  for (let i = 0; i < entries.length; i++) {
    const e = entries[i];
    const time = new Date(e.startedAt).toLocaleTimeString();
    const status = e.status === 'pending' ? ' (pending)' : '';
    const truncMark = e.truncated ? ' [truncated]' : '';
    const source = e.sourceSessionId ? ` from:${e.sourceSessionId.slice(0, 8)}` : '';

    console.log(`--- #${i + 1} [${time}]${source}${status}${truncMark} ---`);
    console.log(`> ${e.prompt}`);
    if (e.response) {
      console.log(e.response);
    }
    console.log('');
  }

  console.log(`${entries.length} entries total.`);
}

function sleep(ms) {
  return new Promise((r) => setTimeout(r, ms));
}

async function setName(target, name) {
  if (!target || !name) {
    console.error('Usage: tt name <id|name> <new-name>');
    process.exit(1);
  }

  const res = await ttFetch(`${BASE}/api/terminals/${encodeURIComponent(target)}/name`, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ name }),
  });

  const result = await res.json();
  if (result.error) {
    console.error(`Error: ${result.error}`);
    process.exit(1);
  }
  console.log(`Terminal ${target} named "${name}".`);
}

async function showSelf() {
  if (!SELF) {
    console.log('Not running inside a terminal-board session.');
    process.exit(1);
  }
  console.log(SELF);
}

async function showStatus(target) {
  if (!target) {
    // Show own status
    if (!SELF) {
      console.error('Not running inside a terminal-board session. Specify a target.');
      process.exit(1);
    }
    target = SELF;
  }

  const res = await ttFetch(`${BASE}/api/terminals/status`);
  const { statuses } = await res.json();

  const resolved = statuses.find(
    (s) =>
      s.sessionId === target ||
      s.sessionId.startsWith(target) ||
      s.name === target
  );

  if (!resolved) {
    console.error(`Terminal not found: ${target}`);
    process.exit(1);
  }

  console.log(JSON.stringify(resolved, null, 2));
}

function formatAgo(timestamp) {
  const seconds = Math.floor((Date.now() - timestamp) / 1000);
  if (seconds < 10) return 'just now';
  if (seconds < 60) return `${seconds}s ago`;
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `${minutes}m ago`;
  const hours = Math.floor(minutes / 60);
  return `${hours}h ago`;
}

async function showPeerStatus(target) {
  // Fetch terminal status
  const statusRes = await ttFetch(`${BASE}/api/terminals/status`);
  const { statuses } = await statusRes.json();
  const status = statuses.find(
    (s) => s.sessionId === target || s.sessionId.startsWith(target) || s.name === target
  );
  if (!status) {
    console.error(`Terminal not found: ${target}`);
    process.exit(1);
  }

  // Fetch latest task for this peer
  const sessionId = SELF || '';
  let taskInfo = '';
  let taskElapsed = '';
  if (sessionId) {
    try {
      const taskRes = await ttFetch(`${BASE}/api/tasks/${encodeURIComponent(sessionId)}`);
      const taskResult = await taskRes.json();
      const tasks = taskResult.tasks || [];
      // Find latest task targeting this peer
      const peerTask = [...tasks].reverse().find(t =>
        t.targetSessionId === status.sessionId || t.targetName === (status.name || status.sessionId.slice(0, 8))
      );
      if (peerTask) {
        const cmd = peerTask.command.length > 50 ? peerTask.command.slice(0, 47) + '...' : peerTask.command;
        taskInfo = cmd;
        taskElapsed = formatDuration(Date.now() - peerTask.createdAt);
      }
    } catch {}
  }

  // Determine state
  let state, stateIcon;
  if (status.isProcessing) {
    state = 'working';
    stateIcon = '⟳';
  } else if (status.isRunning) {
    state = 'running';
    stateIcon = '▶';
  } else {
    state = 'idle';
    stateIcon = '●';
  }

  // Last output ago
  const lastOutputAgo = status.lastOutputAt ? formatAgo(status.lastOutputAt) : 'unknown';

  // Build output line
  const name = status.name || status.sessionId.slice(0, 8);
  let line = `${stateIcon} ${name}: ${state}`;
  if (taskElapsed) line += ` (${taskElapsed})`;
  if (taskInfo) line += ` | Task: "${taskInfo}"`;
  line += ` | Last output: ${lastOutputAgo}`;

  console.log(line);
}

function formatDuration(ms) {
  const totalSec = Math.floor(ms / 1000);
  if (totalSec < 60) return `${totalSec}s`;
  const min = Math.floor(totalSec / 60);
  const sec = totalSec % 60;
  if (min < 60) return `${min}m ${sec}s`;
  const hr = Math.floor(min / 60);
  return `${hr}h ${min % 60}m`;
}

async function showTasks(target) {
  const sessionId = target || SELF;
  if (!sessionId) {
    console.error('Usage: tt tasks [id|name]');
    process.exit(1);
  }

  const res = await ttFetch(`${BASE}/api/tasks/${encodeURIComponent(sessionId)}`);
  const result = await res.json();
  if (result.error) {
    console.error(`Error: ${result.error}`);
    process.exit(1);
  }

  const tasks = result.tasks || [];
  if (tasks.length === 0) {
    console.log('No delegated tasks.');
    return;
  }

  // Show incomplete tasks in detail, then last 5 terminal (done or failed).
  const isTerminal = (s) => s === 'done' || s === 'failed';
  const incomplete = tasks.filter(t => !isTerminal(t.displayStatus));
  const terminal = tasks.filter(t => isTerminal(t.displayStatus));

  const shortTask = (id) => (id || '').slice(0, 8);

  for (const t of incomplete) {
    const tid = shortTask(t.taskId).padEnd(8);
    const name = (t.targetName || '').padEnd(10);
    const cmd = t.command.length > 30 ? t.command.slice(0, 27) + '...' : t.command;
    const cmdPad = cmd.padEnd(32);
    if (t.displayStatus === 'working') {
      console.log(`  ${tid} ${name} ⟳ working  ${cmdPad} (${formatAgo(t.createdAt)})`);
    } else {
      console.log(`  ${tid} ${name} … pending  ${cmdPad} (${formatAgo(t.createdAt)})`);
    }
  }

  const recentTerminal = terminal.slice(-5);
  if (recentTerminal.length > 0) {
    if (incomplete.length > 0) console.log('');
    if (terminal.length > recentTerminal.length) {
      console.log(`  (${terminal.length - recentTerminal.length} older terminal tasks hidden)`);
    }
    for (const t of recentTerminal) {
      const tid = shortTask(t.taskId).padEnd(8);
      const name = (t.targetName || '').padEnd(10);
      const cmd = t.command.length > 30 ? t.command.slice(0, 27) + '...' : t.command;
      const cmdPad = cmd.padEnd(32);
      const icon = t.displayStatus === 'failed' ? '✗ failed  ' : '✓ done    ';
      const resultText = t.result ? `→ ${t.result.slice(0, 50)}` : '';
      console.log(`  ${tid} ${name} ${icon} ${cmdPad} ${resultText}`);
    }
  }

  if (result.summary) {
    console.log(`\n${result.summary.summary}`);
  }
}

async function sendNotification(args) {
  if (args.length < 2) {
    console.error('Usage: tt notify <id|name> <message...>');
    process.exit(1);
  }
  const target = args[0];
  const message = args.slice(1).join(' ');

  const res = await ttFetch(`${BASE}/api/notifications/send`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ target, message, sourceSessionId: SELF || undefined }),
  });
  const result = await res.json();
  if (result.error) {
    console.error(`Error: ${result.error}`);
    process.exit(1);
  }
  process.stderr.write(`Notification sent (${result.notificationId}).\n`);
}

async function showNotifications(...args) {
  let target = null;
  let doClear = false;
  let newOnly = false;
  let doWait = false;
  let sinceSeq = null;        // explicit override; defaults to lastReadSeq when --wait is set
  let timeoutSec = null;
  for (let i = 0; i < args.length; i++) {
    const a = args[i];
    if (a === '--clear') doClear = true;
    else if (a === '--new') newOnly = true;
    else if (a === '--wait') doWait = true;
    else if (a === '--since' && args[i + 1] !== undefined) { sinceSeq = parseInt(args[++i], 10); }
    else if (a === '--timeout' && args[i + 1] !== undefined) { timeoutSec = parseInt(args[++i], 10); }
    else if (!target) target = a;
  }
  const sessionId = target || SELF;
  if (!sessionId) {
    console.error('Usage: tt notifications [id|name] [--new] [--clear] [--wait [--since N] [--timeout SEC]]');
    process.exit(1);
  }

  const enc = encodeURIComponent(sessionId);

  // --wait: long-poll the server. Default sinceSeq is the current lastReadSeq
  // so unread entries are returned immediately, otherwise we block. Loops are
  // the caller's job — this command runs one wait cycle and exits.
  if (doWait) {
    const headRes = await ttFetch(`${BASE}/api/notifications/${enc}`);
    const head = await headRes.json();
    if (head.error) {
      console.error(`Error: ${head.error}`);
      process.exit(1);
    }
    const baselineSeq = sinceSeq !== null ? sinceSeq : (head.lastReadSeq || 0);
    const params = new URLSearchParams({ sinceSeq: String(baselineSeq) });
    if (timeoutSec !== null) params.set('timeout', String(timeoutSec * 1000));
    const waitRes = await ttFetch(`${BASE}/api/notifications/${enc}/wait?${params}`);
    const waitResult = await waitRes.json();
    if (waitResult.error) {
      console.error(`Error: ${waitResult.error}`);
      process.exit(1);
    }
    const items = waitResult.notifications || [];
    if (items.length === 0) {
      console.log(`(timeout — no new notifications since seq=${baselineSeq})`);
      return;
    }
    for (const n of items) {
      const time = new Date(n.timestamp).toLocaleTimeString();
      const tag = n.kind === 'task:complete' && n.taskId
        ? ` [task ${String(n.taskId).slice(0, 8)}]`
        : '';
      console.log(`[${time}] from "${n.sourceName}"${tag}: ${n.message}`);
    }
    const lastSeq = items[items.length - 1]?.seq;
    const seqHint = lastSeq !== undefined ? ` (lastSeq=${lastSeq})` : '';
    console.log(`\n${items.length} notification(s).${seqHint}`);
    // Intentionally no auto-mark-read here. A wait response is a window into
    // the queue; entries that arrive AFTER the response (but before we'd ack)
    // would be silently consumed by a tail-advancing mark-read. Callers that
    // want to ack run `tt notifications [id|name]` (no flag) which acks to
    // the current tail, or use the next `--wait --since <lastSeq>` to
    // explicitly continue from where this batch ended.
    return;
  }

  const res = await ttFetch(`${BASE}/api/notifications/${enc}`);
  const result = await res.json();
  if (result.error) {
    console.error(`Error: ${result.error}`);
    process.exit(1);
  }

  let notifications = result.notifications || [];
  if (newOnly) {
    const lastReadSeq = result.lastReadSeq || 0;
    notifications = notifications.filter(n => n.seq > lastReadSeq);
  }
  if (notifications.length === 0) {
    console.log(newOnly ? 'No new notifications.' : 'No notifications.');
    return;
  }

  for (const n of notifications) {
    const time = new Date(n.timestamp).toLocaleTimeString();
    const statusMark = n.status === 'queued' ? ' [queued]' : '';
    console.log(`[${time}] from "${n.sourceName}"${statusMark}: ${n.message}`);
  }
  const label = newOnly ? 'new notification(s)' : 'notification(s)';
  const totalInfo = newOnly && result.totalCount > notifications.length
    ? ` (${result.totalCount} total)` : '';
  console.log(`\n${notifications.length} ${label}.${totalInfo}`);

  // Mark as read after displaying
  await ttFetch(`${BASE}/api/notifications/${enc}/read`, { method: 'POST' }).catch(() => {});

  // Append task summary — only show details for incomplete tasks
  try {
    const taskRes = await ttFetch(`${BASE}/api/tasks/${enc}`);
    const taskResult = await taskRes.json();
    const tasks = taskResult.tasks || [];
    if (tasks.length > 0) {
      const isTerminal = (s) => s === 'done' || s === 'failed';
      const incomplete = tasks.filter(t => !isTerminal(t.displayStatus));
      if (incomplete.length > 0) {
        console.log('');
        for (const t of incomplete) {
          const tid = (t.taskId || '').slice(0, 8).padEnd(8);
          const name = (t.targetName || '').padEnd(10);
          const cmd = t.command.length > 30 ? t.command.slice(0, 27) + '...' : t.command;
          const cmdPad = cmd.padEnd(32);
          if (t.displayStatus === 'working') {
            console.log(`  ${tid} ${name} ⟳ working  ${cmdPad} (${formatAgo(t.createdAt)})`);
          } else {
            console.log(`  ${tid} ${name} … pending  ${cmdPad} (${formatAgo(t.createdAt)})`);
          }
        }
      }
      if (taskResult.summary) {
        console.log(`\n${taskResult.summary.summary}`);
      }
    }
  } catch {}

  if (doClear) {
    await ttFetch(`${BASE}/api/notifications/${enc}`, { method: 'DELETE' });
    process.stderr.write('Notifications cleared.\n');
  }
}

async function showPeerOutput(target, filename) {
  if (!target) {
    console.error('Usage: tt peer output [peer] [filename]');
    process.exit(1);
  }

  const enc = encodeURIComponent(target);

  if (filename) {
    // Read specific file
    const res = await ttFetch(`${BASE}/api/output/${enc}/${encodeURIComponent(filename)}`);
    const result = await res.json();
    if (result.error) {
      console.error(`Error: ${result.error}`);
      process.exit(1);
    }
    process.stdout.write(result.content);
    if (result.content && !result.content.endsWith('\n')) process.stdout.write('\n');
    return;
  }

  // List files
  const res = await ttFetch(`${BASE}/api/output/${enc}`);
  const result = await res.json();
  if (result.error) {
    console.error(`Error: ${result.error}`);
    process.exit(1);
  }

  const files = result.files || [];
  if (files.length === 0) {
    console.log(`No output files.${result.outputDir ? ` (dir: ${result.outputDir})` : ''}`);
    return;
  }

  console.log(pad('FILE', 30) + pad('SIZE', 10) + 'MODIFIED');
  console.log('-'.repeat(60));
  for (const f of files) {
    const size = f.size < 1024 ? `${f.size}B` : f.size < 1048576 ? `${(f.size / 1024).toFixed(1)}K` : `${(f.size / 1048576).toFixed(1)}M`;
    const date = new Date(f.mtime).toLocaleString();
    console.log(pad(f.name, 30) + pad(size, 10) + date);
  }
}

async function listPeers() {
  if (!SELF) {
    console.error('Not running inside a terminal-board session.');
    process.exit(1);
  }

  const res = await ttFetch(`${BASE}/api/links/peers/${SELF}`);
  const { peers } = await res.json();

  if (!peers || peers.length === 0) {
    console.log('No linked peers. Drag a link line to connect terminals.');
    return;
  }

  console.log(pad('ID', 10) + pad('NAME', 12) + 'STATUS');
  console.log('-'.repeat(36));
  for (const p of peers) {
    const status = p.disconnected ? 'disconnected' : 'active';
    console.log(pad(p.shortId, 10) + pad(p.name || '-', 12) + status);
  }
}

async function peerCommand(args) {
  if (!SELF) {
    console.error('Not running inside a terminal-board session.');
    process.exit(1);
  }

  const subCmd = args[0];
  if (!subCmd) {
    console.error('Usage: tt peer <send|notify|tasks|read|last|history> [args...]');
    process.exit(1);
  }

  // Get peer — if only one peer, use it automatically; otherwise require name/id
  const peers = await getPeers();
  if (peers.length === 0) {
    console.error('No linked peers. Drag a link line to connect terminals.');
    process.exit(1);
  }

  switch (subCmd) {
    case 'send': {
      const { target, rest } = resolvePeerTarget(peers, args.slice(1));
      if (rest.length === 0) {
        console.error('Usage: tt peer send [id|name] <command...>');
        process.exit(1);
      }
      return sendCommand([target, ...rest]);
    }
    case 'ipc': {
      const { target, rest } = resolvePeerTarget(peers, args.slice(1));
      if (rest.length === 0) {
        console.error('Usage: tt peer ipc [id|name] <message...>');
        process.exit(1);
      }
      return ipcSendAndWait([target, ...rest]);
    }
    case 'read': {
      const { target, rest } = resolvePeerTarget(peers, args.slice(1));
      return readOutput(target, ...rest);
    }
    case 'last': {
      const { target, rest } = resolvePeerTarget(peers, args.slice(1));
      return readLast(target, ...rest);
    }
    case 'history': {
      const { target } = resolvePeerTarget(peers, args.slice(1));
      return showHistory(target);
    }
    case 'notify': {
      const { target, rest } = resolvePeerTarget(peers, args.slice(1));
      if (rest.length === 0) {
        console.error('Usage: tt peer notify [id|name] <message...>');
        process.exit(1);
      }
      return sendNotification([target, ...rest]);
    }
    case 'status': {
      const { target } = resolvePeerTarget(peers, args.slice(1));
      return showPeerStatus(target);
    }
    case 'output': {
      const { target, rest } = resolvePeerTarget(peers, args.slice(1));
      return showPeerOutput(target, rest[0]);
    }
    case 'tasks':
      return showTasks(SELF);
    default:
      console.error(`Unknown peer subcommand: ${subCmd}`);
      console.error('Available: send, notify, status, tasks, read, last, history, output');
      process.exit(1);
  }
}

async function getPeers() {
  const res = await ttFetch(`${BASE}/api/links/peers/${SELF}`);
  const { peers } = await res.json();
  return peers || [];
}

/**
 * Resolve the peer target. If only one active peer, use it automatically.
 * Otherwise, the first arg must be a peer id/name.
 * Errors if the specified target matches a recently-disconnected peer.
 */
function resolvePeerTarget(peers, args) {
  const activePeers = peers.filter(p => !p.disconnected);
  const disconnectedPeers = peers.filter(p => p.disconnected);

  // Separate flags/numeric args from potential peer identifiers
  const isFlag = (a) => String(a).startsWith('--') || /^\d+$/.test(String(a));
  const peerArgs = args.filter(a => !isFlag(a));
  const firstPeerArg = peerArgs[0];

  // Check if first non-flag arg explicitly matches a disconnected peer → error
  if (firstPeerArg && disconnectedPeers.length > 0) {
    const dc = disconnectedPeers.find(p =>
      p.name === firstPeerArg || p.shortId === firstPeerArg || p.sessionId.startsWith(firstPeerArg)
    );
    if (dc) {
      console.error(`Error: Peer "${dc.name || dc.shortId}" is disconnected.`);
      process.exit(1);
    }
  }

  // Check if first non-flag arg explicitly matches an active peer → consume it
  if (firstPeerArg && activePeers.length > 0) {
    const match = activePeers.find(p =>
      p.name === firstPeerArg || p.shortId === firstPeerArg || p.sessionId.startsWith(firstPeerArg)
    );
    if (match) {
      const idx = args.indexOf(firstPeerArg);
      // Use full sessionId to avoid name collisions in resolveSession
      return { target: match.sessionId, rest: [...args.slice(0, idx), ...args.slice(idx + 1)] };
    }
  }

  if (activePeers.length === 1) {
    // Single active peer — use full sessionId to avoid name collisions
    return { target: activePeers[0].sessionId, rest: args };
  }

  if (activePeers.length === 0) {
    console.error('No active peers. All linked peers have disconnected.');
    process.exit(1);
  }

  // Multiple active peers — first non-flag arg must identify the peer
  if (!firstPeerArg) {
    console.error('Multiple peers linked. Specify which one:');
    for (const p of activePeers) {
      console.error(`  ${p.shortId}  ${p.name || ''}`);
    }
    process.exit(1);
  }

  const idx = args.indexOf(firstPeerArg);
  return { target: firstPeerArg, rest: [...args.slice(0, idx), ...args.slice(idx + 1)] };
}

/**
 * `tt task` — structured task lifecycle commands.
 *   tt task complete <task_id> [--summary "..."] [--report <file>]
 *                               [--changed "f1,f2"] [--unresolved "..."] [--failed]
 *   tt task current               Show the latest pending task where SELF is the target (SUB view)
 *   tt task show <task_id>        Show full task detail
 *   tt task dir <task_id>         Print the absolute path of the task's output directory
 *   tt task report <task_id>      Read the SUB's report file for this task
 *   tt task manifest <task_id>    Read the structured manifest.json for this task
 *   tt task files <task_id>       List files in the task's output directory
 *   tt task ls                    List tasks where SELF is MAIN (same as `tt tasks`)
 */
async function taskCommand(args) {
  const sub = args[0];
  if (!sub) {
    console.error('Usage: tt task <complete|current|show|dir|report|manifest|files|ls> [args...]');
    process.exit(1);
  }

  switch (sub) {
    case 'complete':
      return taskComplete(args.slice(1));
    case 'current':
      return taskCurrent();
    case 'show':
      return taskShow(args[1]);
    case 'dir':
      return taskDir(args[1]);
    case 'report':
      return taskReport(args[1]);
    case 'manifest':
      return taskManifest(args[1]);
    case 'files':
      return taskFiles(args[1]);
    case 'ls':
    case 'list':
      return showTasks(SELF);
    default:
      console.error(`Unknown task subcommand: ${sub}`);
      console.error('Available: complete, current, show, dir, report, manifest, files, ls');
      process.exit(1);
  }
}

async function taskComplete(args) {
  if (!args[0] || args[0].startsWith('--')) {
    console.error('Usage: tt task complete <task_id> [--summary "..."] [--report <file>] [--changed "f1,f2"] [--unresolved "..."] [--failed]');
    process.exit(1);
  }
  const taskId = args[0];
  let summary, reportFile;
  let changed, unresolved;
  let status = 'done';

  for (let i = 1; i < args.length; i++) {
    const a = args[i];
    if (a === '--summary') { summary = args[++i]; }
    else if (a === '--report') { reportFile = args[++i]; }
    else if (a === '--changed') { changed = args[++i]; }
    else if (a === '--unresolved') { unresolved = args[++i]; }
    else if (a === '--failed') { status = 'failed'; }
    else if (a.startsWith('--summary=')) { summary = a.slice('--summary='.length); }
    else if (a.startsWith('--report=')) { reportFile = a.slice('--report='.length); }
    else if (a.startsWith('--changed=')) { changed = a.slice('--changed='.length); }
    else if (a.startsWith('--unresolved=')) { unresolved = a.slice('--unresolved='.length); }
    else {
      console.error(`Unknown flag: ${a}`);
      process.exit(1);
    }
  }

  const toList = (v) => {
    if (v === undefined) return undefined;
    const t = String(v).trim();
    if (!t || /^(none|n\/a|-)$/i.test(t)) return [];
    return t.split(',').map(s => s.trim()).filter(Boolean);
  };

  const body = {
    sourceSessionId: SELF || undefined,
    status,
    summary,
    reportFile,
    changed: toList(changed),
    unresolved: toList(unresolved),
  };

  const headers = { 'Content-Type': 'application/json' };
  if (TOKEN) headers['X-Tboard-Token'] = TOKEN;
  const res = await ttFetch(`${BASE}/api/tasks/${encodeURIComponent(taskId)}/complete`, {
    method: 'POST',
    headers,
    body: JSON.stringify(body),
  });
  const result = await res.json();
  if (result.error) {
    console.error(`Error: ${result.error}`);
    process.exit(1);
  }
  const t = result.task || {};
  console.log(`Task ${taskId} marked ${t.status || status}.`);
}

async function taskCurrent() {
  if (!SELF) {
    console.error('Not running inside a terminal-board session.');
    process.exit(1);
  }

  // Scan tasks from each MAIN peer for pending tasks addressed to SELF.
  const peers = await getPeers().catch(() => []);
  const pending = [];
  for (const p of peers) {
    try {
      const res = await ttFetch(`${BASE}/api/tasks/${encodeURIComponent(p.sessionId)}`);
      const data = await res.json();
      for (const t of data.tasks || []) {
        if (t.targetSessionId === SELF && t.status === 'pending') pending.push(t);
      }
    } catch {}
  }

  if (pending.length === 0) {
    console.log('No pending task directed at this terminal.');
    return;
  }

  pending.sort((a, b) => a.createdAt - b.createdAt); // oldest first
  if (pending.length === 1) {
    console.log(pending[0].taskId);
    return;
  }

  // Multiple pending — refuse to guess. Candidates go to stderr only so that
  // shell substitutions like $(tt task current) stay empty rather than get
  // a contaminated multi-line value.
  console.error(`Warning: ${pending.length} pending tasks directed at this terminal.`);
  console.error('Use the task_id from the "[tboard task_id=<id>]" prefix of the specific task.');
  console.error('Candidates:');
  for (const t of pending) {
    const cmd = (t.command || '').replace(/\s+/g, ' ').slice(0, 60);
    console.error(`  ${t.taskId}  ${cmd}`);
  }
  process.exit(2);
}

async function taskShow(taskId) {
  if (!taskId) {
    console.error('Usage: tt task show <task_id>');
    process.exit(1);
  }
  const res = await ttFetch(`${BASE}/api/tasks/by-id/${encodeURIComponent(taskId)}`);
  const data = await res.json();
  if (data.error) {
    console.error(`Error: ${data.error}`);
    process.exit(1);
  }
  console.log(JSON.stringify(data.task, null, 2));
}

async function taskDir(taskId) {
  if (!taskId) {
    console.error('Usage: tt task dir <task_id>');
    process.exit(1);
  }
  const res = await ttFetch(`${BASE}/api/tasks/by-id/${encodeURIComponent(taskId)}/dir`);
  const data = await res.json();
  if (data.error) {
    console.error(`Error: ${data.error}`);
    process.exit(1);
  }
  console.log(data.dir);
}

async function taskReport(taskId) {
  if (!taskId) {
    console.error('Usage: tt task report <task_id>');
    process.exit(1);
  }
  const res = await ttFetch(`${BASE}/api/tasks/by-id/${encodeURIComponent(taskId)}/report`);
  const data = await res.json();
  if (data.error) {
    console.error(`Error: ${data.error}`);
    process.exit(1);
  }
  process.stdout.write(data.content);
  if (data.content && !data.content.endsWith('\n')) process.stdout.write('\n');
}

async function taskManifest(taskId) {
  if (!taskId) {
    console.error('Usage: tt task manifest <task_id>');
    process.exit(1);
  }
  const res = await ttFetch(`${BASE}/api/tasks/by-id/${encodeURIComponent(taskId)}/manifest`);
  const data = await res.json();
  if (data.error) {
    console.error(`Error: ${data.error}`);
    process.exit(1);
  }
  console.log(JSON.stringify(data.manifest, null, 2));
}

async function taskFiles(taskId) {
  if (!taskId) {
    console.error('Usage: tt task files <task_id>');
    process.exit(1);
  }
  const res = await ttFetch(`${BASE}/api/tasks/by-id/${encodeURIComponent(taskId)}/files`);
  const data = await res.json();
  if (data.error) {
    console.error(`Error: ${data.error}`);
    process.exit(1);
  }
  const files = data.files || [];
  if (files.length === 0) {
    console.log(`No files.${data.dir ? ` (dir: ${data.dir})` : ''}`);
    return;
  }
  console.log(pad('FILE', 30) + pad('SIZE', 10) + 'MODIFIED');
  console.log('-'.repeat(60));
  for (const f of files) {
    const size = f.size < 1024 ? `${f.size}B` : f.size < 1048576 ? `${(f.size / 1024).toFixed(1)}K` : `${(f.size / 1048576).toFixed(1)}M`;
    const date = new Date(f.mtime).toLocaleString();
    console.log(pad(f.name, 30) + pad(size, 10) + date);
  }
  if (data.dir) console.log(`\n(dir: ${data.dir})`);
}

/**
 * Phase 3: MCP stdio server. Thin adapter over the existing task API.
 *
 * Exposed tools:
 *   Core task lifecycle (Phase 3a):
 *     tboard_peer_list       — list linked peers for this session
 *     tboard_task_send       — dispatch a task to a peer (MAIN→SUB; returns taskId)
 *     tboard_task_current    — metadata of the pending task targeted at SELF
 *     tboard_task_get        — full task detail by task_id (includes outputDir)
 *     tboard_task_complete   — close a task with structured summary / report / etc.
 *   Convenience reads / notify (Phase 3b):
 *     tboard_peer_notify     — deliver a UI-only bubble (does NOT change task state)
 *     tboard_task_report     — read the SUB's report file for a task
 *     tboard_task_manifest   — read the parsed manifest.json for a task
 *     tboard_task_files      — list files in the task output directory
 *   Notification read path (Phase 4a):
 *     tboard_notifications_list       — non-PTY notification read (supports unreadOnly)
 *     tboard_notifications_mark_read  — advance the last-read-seq marker
 *
 * Transport: stdio only. Only JSON-RPC frames on stdout; diagnostics go to stderr.
 * Auth: reuses the existing TBOARD_TOKEN issued at pty creation. Fail-fast if
 * TBOARD_SESSION or TBOARD_TOKEN is absent — this server is only meaningful
 * inside a tboard-managed pty session.
 */
async function mcpStdioServer() {
  // Fail-fast identity guards. Errors go to stderr; stdout stays clean for
  // JSON-RPC frames even if we never get to connect().
  if (!SELF) {
    process.stderr.write('tt mcp-stdio: TBOARD_SESSION is not set; run inside a tboard pty session.\n');
    process.exit(1);
  }
  if (!TOKEN) {
    process.stderr.write('tt mcp-stdio: TBOARD_TOKEN is not set; run inside a tboard pty session.\n');
    process.exit(1);
  }
  // Probe connectivity so a broken env fails at startup rather than on first tool call.
  // Resolution order mirrors every other `tt` command:
  //   1. Unix socket (TBOARD_SOCKET) if set — ttFetch handles that transparently.
  //   2. TBOARD_URL if set.
  //   3. Port-scan fallback via detectBase().
  // We explicitly call detectBase() first so that a socket-only env does not
  // depend on a hardcoded HTTP port as a probe target.
  if (!SOCKET_PATH && !BASE) await detectBase();
  try {
    const probeBase = BASE || 'http://127.0.0.1:3001'; // only used when ttFetch falls through to HTTP
    const probe = await ttFetch(`${probeBase}/api/terminals/status`);
    if (!probe.ok) throw new Error(`probe returned HTTP ${probe.status}`);
  } catch (e) {
    process.stderr.write(`tt mcp-stdio: cannot reach tboard server (${(e && e.message) || e}).\n`);
    process.exit(1);
  }

  const { McpServer } = await import('@modelcontextprotocol/sdk/server/mcp.js');
  const { StdioServerTransport } = await import('@modelcontextprotocol/sdk/server/stdio.js');
  const { z } = await import('zod');

  const server = new McpServer({ name: 'tboard', version: '1.0.0' });

  // Shared JSON parse — body-text first so we can surface non-JSON responses.
  const asJson = async (res) => {
    const text = await res.text();
    try { return { ok: true, data: JSON.parse(text) }; }
    catch { return { ok: false, error: `Non-JSON response (status=${res.status}): ${text.slice(0, 200)}` }; }
  };

  // Map HTTP error responses to MCP tool-call errors. The callback wrapper
  // below catches throws and returns them as `isError: true` results so the
  // MCP client sees a clean error instead of a crashed connection.
  const toolError = (message) => ({
    content: [{ type: 'text', text: message }],
    isError: true,
  });

  const runTool = async (fn) => {
    try { return await fn(); }
    catch (e) { return toolError((e && e.message) || String(e)); }
  };

  server.registerTool('tboard_peer_list', {
    title: 'List linked peers',
    description: 'Return the peers this session is linked to, with canonical sessionId values. Prefer these IDs for other tools.',
    inputSchema: {},
  }, async () => runTool(async () => {
    const res = await ttFetch(`${BASE}/api/links/peers/${encodeURIComponent(SELF)}`);
    const parsed = await asJson(res);
    if (!parsed.ok) throw new Error(parsed.error);
    if (parsed.data.error) throw new Error(parsed.data.error);
    const peers = parsed.data.peers || [];
    return {
      content: [{ type: 'text', text: JSON.stringify(peers, null, 2) }],
      structuredContent: { peers },
    };
  }));

  server.registerTool('tboard_task_send', {
    title: 'Dispatch a task to a peer (MAIN → SUB)',
    description: 'Paste a task message into the target peer and register a task. Returns the assigned task_id. Use the canonical sessionId from tboard_peer_list. MAIN-only: the server only registers a task when this session is the MAIN for the target peer; calling this from a SUB results in an error.',
    inputSchema: {
      targetSessionId: z.string().min(1).describe('Canonical session id of the target peer'),
      message: z.string().min(1).describe('Task content to paste into the peer'),
    },
  }, async ({ targetSessionId, message }) => runTool(async () => {
    const res = await ttFetch(`${BASE}/api/tasks/send`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ target: targetSessionId, message, sourceSessionId: SELF }),
    });
    const parsed = await asJson(res);
    if (!parsed.ok) throw new Error(parsed.error);
    if (parsed.data.error) throw new Error(parsed.data.error);
    // The server only returns a taskId when this is a MAIN → SUB dispatch.
    // For any other direction (peer-to-peer that is not MAIN→SUB) the HTTP
    // call still pastes text but no structured task exists, which would
    // silently erode the task protocol. Treat this as a hard error so the
    // caller does not think a task was registered.
    if (!parsed.data.taskId) {
      throw new Error(
        'No task was registered. tboard_task_send is MAIN→SUB only; this session is not the MAIN for the given targetSessionId. ' +
        'Use tboard_peer_list to verify the link direction, or reconnect the peers with this session as the MAIN.'
      );
    }
    const out = { taskId: parsed.data.taskId, targetSessionId: parsed.data.sessionId };
    return {
      content: [{ type: 'text', text: JSON.stringify(out, null, 2) }],
      structuredContent: out,
    };
  }));

  server.registerTool('tboard_task_current', {
    title: 'Get the single pending task addressed at this session',
    description: 'Return metadata for the pending task targeted at this session (this SUB), including taskId, outputDir, sourceSessionId, createdAt, and command. When no task is pending, returns { task: null }. When MULTIPLE tasks are pending, returns an error with the candidate list — callers MUST disambiguate by reading the `[tboard task_id=<id>]` prefix of the specific task they intend to act on and using tboard_task_get, never guess.',
    inputSchema: {},
  }, async () => runTool(async () => {
    const peersRes = await ttFetch(`${BASE}/api/links/peers/${encodeURIComponent(SELF)}`);
    const peersParsed = await asJson(peersRes);
    if (!peersParsed.ok) throw new Error(peersParsed.error);
    if (peersParsed.data.error) throw new Error(peersParsed.data.error);
    const pending = [];
    for (const p of peersParsed.data.peers || []) {
      try {
        const r = await ttFetch(`${BASE}/api/tasks/${encodeURIComponent(p.sessionId)}`);
        const d = await asJson(r);
        if (!d.ok || d.data.error) continue;
        for (const t of d.data.tasks || []) {
          if (t.targetSessionId === SELF && t.status === 'pending') pending.push(t);
        }
      } catch { /* skip peers that fail */ }
    }
    if (pending.length === 0) {
      return {
        content: [{ type: 'text', text: JSON.stringify({ task: null }, null, 2) }],
        structuredContent: { task: null },
      };
    }
    if (pending.length > 1) {
      // Never guess. The caller must disambiguate using the task_id prefix
      // embedded in the specific task's paste. Surface as a tool error with
      // the candidate list so the agent sees exactly what's ambiguous.
      pending.sort((a, b) => a.createdAt - b.createdAt);
      const candidates = pending.map(t => ({
        taskId: t.taskId,
        createdAt: t.createdAt,
        command: (t.command || '').slice(0, 120),
      }));
      throw new Error(
        `Ambiguous: ${pending.length} pending tasks are addressed at this session. ` +
        'Read the `[tboard task_id=<id>]` prefix of the specific task you intend to act on ' +
        'and pass that id to tboard_task_get / tboard_task_complete. ' +
        'Candidates: ' + JSON.stringify(candidates)
      );
    }
    const only = pending[0];
    return {
      content: [{ type: 'text', text: JSON.stringify({ task: only }, null, 2) }],
      structuredContent: { task: only },
    };
  }));

  server.registerTool('tboard_task_get', {
    title: 'Get a task by its task_id',
    description: 'Return the full task object keyed by task_id, including the frozen outputDir and current status. Works even after session churn via the server-side filesystem fallback.',
    inputSchema: {
      taskId: z.string().min(1),
    },
  }, async ({ taskId }) => runTool(async () => {
    const res = await ttFetch(`${BASE}/api/tasks/by-id/${encodeURIComponent(taskId)}`);
    const parsed = await asJson(res);
    if (!parsed.ok) throw new Error(parsed.error);
    if (parsed.data.error) throw new Error(parsed.data.error);
    return {
      content: [{ type: 'text', text: JSON.stringify(parsed.data, null, 2) }],
      structuredContent: parsed.data,
    };
  }));

  server.registerTool('tboard_task_complete', {
    title: 'Close a task with a structured result',
    description: 'Mark the task done or failed. reportFile must be a bare filename (no paths); the server resolves it under the task output directory. Changed / unresolved accept arrays of strings.',
    inputSchema: {
      taskId: z.string().min(1),
      summary: z.string().optional(),
      reportFile: z.string().optional().describe('Bare filename written inside the task output directory'),
      changed: z.array(z.string()).optional(),
      unresolved: z.array(z.string()).optional(),
      status: z.enum(['done', 'failed']).optional().describe('Defaults to "done"'),
    },
  }, async ({ taskId, summary, reportFile, changed, unresolved, status }) => runTool(async () => {
    const body = {
      sourceSessionId: SELF,
      status: status || 'done',
    };
    if (summary !== undefined) body.summary = summary;
    if (reportFile !== undefined) body.reportFile = reportFile;
    if (changed !== undefined) body.changed = changed;
    if (unresolved !== undefined) body.unresolved = unresolved;
    const res = await ttFetch(`${BASE}/api/tasks/${encodeURIComponent(taskId)}/complete`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Tboard-Token': TOKEN },
      body: JSON.stringify(body),
    });
    const parsed = await asJson(res);
    if (!parsed.ok) throw new Error(parsed.error);
    if (parsed.data.error) throw new Error(parsed.data.error);
    return {
      content: [{ type: 'text', text: JSON.stringify({ task: parsed.data.task }, null, 2) }],
      structuredContent: { task: parsed.data.task },
    };
  }));

  // ── Phase 3b: convenience read / notify tools ─────────────────────
  // These are strictly read-only except for tboard_peer_notify, which writes
  // an informational UI bubble (does NOT change task state). All are keyed on
  // task_id or canonical sessionId; none accept fuzzy targeting.

  server.registerTool('tboard_peer_notify', {
    title: 'Send a UI notification to a peer',
    description: 'Deliver a best-effort UI bubble to the target peer. Informational only — does NOT change task state. Use tboard_task_complete to close tasks.',
    inputSchema: {
      targetSessionId: z.string().min(1).describe('Canonical session id of the target peer'),
      message: z.string().min(1),
    },
  }, async ({ targetSessionId, message }) => runTool(async () => {
    const res = await ttFetch(`${BASE}/api/notifications/send`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ target: targetSessionId, message, sourceSessionId: SELF }),
    });
    const parsed = await asJson(res);
    if (!parsed.ok) throw new Error(parsed.error);
    if (parsed.data.error) throw new Error(parsed.data.error);
    const out = { notificationId: parsed.data.notificationId, targetSessionId: parsed.data.sessionId };
    return {
      content: [{ type: 'text', text: JSON.stringify(out, null, 2) }],
      structuredContent: out,
    };
  }));

  server.registerTool('tboard_task_report', {
    title: 'Read a task report file',
    description: 'Return the text content of the report file SUB wrote for this task (the file named in task.reportFile, resolved under the task output dir).',
    inputSchema: {
      taskId: z.string().min(1),
    },
  }, async ({ taskId }) => runTool(async () => {
    const res = await ttFetch(`${BASE}/api/tasks/by-id/${encodeURIComponent(taskId)}/report`);
    const parsed = await asJson(res);
    if (!parsed.ok) throw new Error(parsed.error);
    if (parsed.data.error) throw new Error(parsed.data.error);
    return {
      content: [{ type: 'text', text: parsed.data.content || '' }],
      structuredContent: { taskId, filename: parsed.data.filename, content: parsed.data.content || '' },
    };
  }));

  server.registerTool('tboard_task_manifest', {
    title: 'Read the structured manifest.json for a task',
    description: 'Return the parsed manifest.json written atomically at task completion. Contains task_id, status, summary, report_file, changed, unresolved, timestamps.',
    inputSchema: {
      taskId: z.string().min(1),
    },
  }, async ({ taskId }) => runTool(async () => {
    const res = await ttFetch(`${BASE}/api/tasks/by-id/${encodeURIComponent(taskId)}/manifest`);
    const parsed = await asJson(res);
    if (!parsed.ok) throw new Error(parsed.error);
    if (parsed.data.error) throw new Error(parsed.data.error);
    return {
      content: [{ type: 'text', text: JSON.stringify(parsed.data.manifest, null, 2) }],
      structuredContent: { taskId, manifest: parsed.data.manifest },
    };
  }));

  server.registerTool('tboard_task_files', {
    title: 'List files in a task output directory',
    description: 'Return the list of files (name, size, mtime) in the task-scoped output directory. Useful for discovering what SUB wrote beyond the declared report.',
    inputSchema: {
      taskId: z.string().min(1),
    },
  }, async ({ taskId }) => runTool(async () => {
    const res = await ttFetch(`${BASE}/api/tasks/by-id/${encodeURIComponent(taskId)}/files`);
    const parsed = await asJson(res);
    if (!parsed.ok) throw new Error(parsed.error);
    if (parsed.data.error) throw new Error(parsed.data.error);
    return {
      content: [{ type: 'text', text: JSON.stringify(parsed.data.files || [], null, 2) }],
      structuredContent: { taskId, dir: parsed.data.dir, files: parsed.data.files || [] },
    };
  }));

  // Phase 4a: non-PTY notification read path. Lets agents consume incoming UI
  // notifications through MCP instead of relying on the PTY auto-inject, which
  // is moving toward compatibility mode (see TBOARD_AUTO_INJECT).
  server.registerTool('tboard_notifications_list', {
    title: 'List notifications addressed at this session',
    description: 'Return notifications queued for THIS session (the caller of mcp-stdio). Pass `unreadOnly: true` to limit to entries whose seq is greater than the last-read marker. Does NOT mark them read — use tboard_notifications_mark_read for that.',
    inputSchema: {
      unreadOnly: z.boolean().optional().describe('Filter to entries with seq > lastReadSeq. Default false.'),
    },
  }, async ({ unreadOnly }) => runTool(async () => {
    const res = await ttFetch(`${BASE}/api/notifications/${encodeURIComponent(SELF)}`);
    const parsed = await asJson(res);
    if (!parsed.ok) throw new Error(parsed.error);
    if (parsed.data.error) throw new Error(parsed.data.error);
    const all = parsed.data.notifications || [];
    const lastReadSeq = parsed.data.lastReadSeq || 0;
    const items = unreadOnly ? all.filter(n => (n.seq ?? 0) > lastReadSeq) : all;
    return {
      content: [{ type: 'text', text: JSON.stringify(items, null, 2) }],
      structuredContent: {
        notifications: items,
        lastReadSeq,
        totalCount: parsed.data.totalCount ?? all.length,
        unreadOnly: !!unreadOnly,
      },
    };
  }));

  server.registerTool('tboard_notifications_wait', {
    title: 'Long-poll for new notifications addressed at this session',
    description: 'Block until a notification with seq > sinceSeq arrives, then return all matching entries. Returns empty (timedOut: true) on timeout. One-shot — re-call with the latest seq to keep listening. Pass sinceSeq=0 (default) to receive everything currently queued plus any that arrive within the timeout. Default timeout 25s, max 60s.',
    inputSchema: {
      sinceSeq: z.number().int().nonnegative().optional().describe('Return only entries with seq strictly greater than this. Default 0 (everything).'),
      timeoutSec: z.number().int().positive().max(60).optional().describe('Max seconds to wait when the queue is empty. Default 25, max 60.'),
    },
  }, async ({ sinceSeq, timeoutSec }) => runTool(async () => {
    const params = new URLSearchParams();
    if (sinceSeq !== undefined) params.set('sinceSeq', String(sinceSeq));
    if (timeoutSec !== undefined) params.set('timeout', String(timeoutSec * 1000));
    const url = `${BASE}/api/notifications/${encodeURIComponent(SELF)}/wait${params.toString() ? `?${params}` : ''}`;
    const res = await ttFetch(url);
    const parsed = await asJson(res);
    if (!parsed.ok) throw new Error(parsed.error);
    if (parsed.data.error) throw new Error(parsed.data.error);
    const items = parsed.data.notifications || [];
    return {
      content: [{ type: 'text', text: JSON.stringify(items, null, 2) }],
      structuredContent: {
        notifications: items,
        lastReadSeq: parsed.data.lastReadSeq ?? 0,
        totalCount: parsed.data.totalCount ?? items.length,
        timedOut: !!parsed.data.timedOut,
      },
    };
  }));

  server.registerTool('tboard_notifications_mark_read', {
    title: 'Mark all notifications for this session as read',
    description: 'Advance the last-read-seq marker to the current tail. Subsequent tboard_notifications_list calls with unreadOnly=true will return nothing until new notifications arrive.',
    inputSchema: {},
  }, async () => runTool(async () => {
    const res = await ttFetch(`${BASE}/api/notifications/${encodeURIComponent(SELF)}/read`, {
      method: 'POST',
    });
    const parsed = await asJson(res);
    if (!parsed.ok) throw new Error(parsed.error);
    if (parsed.data.error) throw new Error(parsed.data.error);
    return {
      content: [{ type: 'text', text: JSON.stringify({ lastReadSeq: parsed.data.lastReadSeq }, null, 2) }],
      structuredContent: { lastReadSeq: parsed.data.lastReadSeq },
    };
  }));

  const transport = new StdioServerTransport();
  await server.connect(transport);
}

async function linkReconnect(args) {
  if (!SELF) {
    console.error('Not running inside a terminal-board session.');
    process.exit(1);
  }

  // Parse: tt link <new-session-id> --as <name>
  let newTarget = null;
  let asName = null;
  for (let i = 0; i < args.length; i++) {
    if (args[i] === '--as' && args[i + 1]) {
      asName = args[i + 1];
      i++;
    } else if (!newTarget) {
      newTarget = args[i];
    }
  }

  if (!newTarget || !asName) {
    console.error('Usage: tt link <new-session-id|name> --as <peer-name>');
    process.exit(1);
  }

  const res = await ttFetch(`${BASE}/api/links/reconnect`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ sourceId: SELF, newTargetId: newTarget, asName }),
  });

  const result = await res.json();
  if (result.error) {
    console.error(`Error: ${result.error}`);
    process.exit(1);
  }
  console.log(`Linked ${result.sessionId.slice(0, 8)} as "${asName}".`);
}

function printHelp() {
  console.log(`tt - Terminal Board CLI

Usage:
  tt ls                              List all terminals (* = self, + = peer)
  tt send <id|name> <command>        Send command (auto-appends Enter)
  tt send <id|name> --file <path>   Send file contents as command
  tt send <id|name> --raw <text>     Send text without Enter
  tt ipc <id|name> <message>         (deprecated) Send message & wait for response
  tt last <id|name>                  Read the last response from an agent
  tt last <id|name> --wait           Wait for agent to finish, then read response
  tt history <id|name>               Show IPC conversation history
  tt read <id|name> [lines]          Read terminal output (clean)
  tt read <id|name> --since-send     Read output since last sent task
                                     (prefers task capture when linked; rendered-buffer fallback otherwise)
  tt read <id|name> --all            Read all available output
  tt read <id|name> --full           Read full task output from disk (no buffer limit)
  tt read <id|name> --wait           Wait until agent finishes, then read
  tt name <id|name> <new-name>       Name a terminal for easy reference
  tt notify <id|name> <message>       Send notification (fire-and-forget)
  tt notifications [id|name]         Show notifications (auto marks read)
  tt notifications [id|name] --new   Show only unread notifications
  tt notifications [id|name] --wait  Long-poll for next notification (default 25s)
                                     Optional: --since <seq> --timeout <sec>
  tt tasks [id|name]                  Show delegated task status
  tt task complete <id> [flags]      Mark a task done/failed (primary completion path)
                                     Flags: --summary "..." --report <file>
                                            --changed "f1,f2" --unresolved "..." --failed
  tt task current                    Print task_id for the latest pending task directed at SELF
  tt task show <task_id>             Show structured detail for one task
  tt task dir <task_id>              Print the output directory for this task (where SUB writes reports)
  tt task report <task_id>           Read the report file SUB wrote for this task
  tt task manifest <task_id>         Read the structured manifest.json for this task
  tt task files <task_id>            List files in the task's output directory
  tt task ls                         List tasks where SELF is MAIN (alias of "tt tasks")
  tt link <id|name> --as <name>     Reconnect a new session as a disconnected peer
  tt status [id|name]                Show terminal status as JSON
  tt self                            Show this terminal's session ID
  tt mcp-stdio                       Run an MCP stdio server exposing the task API
                                     (for agent integration — opt-in via .mcp.json)

Peer commands (linked terminals):
  tt peers                           List linked peers
  tt peer send [id|name] <command>   Send command to peer
  tt peer send [id|name] --file <p> Send file contents to peer
  tt peer status [id|name]           Show peer's working status (1-line)
  tt peer ipc [id|name] <message>    (deprecated) Send IPC message to peer & wait
  tt peer notify [id|name] <message> Send notification to peer (non-blocking)
  tt peer tasks                        Show delegated task status
  tt peer read [id|name] [lines]     Read peer's terminal output (clean)
  tt peer read [id|name] --since-send Read output since last sent task (task capture preferred)
  tt peer read [id|name] --all       Read all available peer output
  tt peer read [id|name] --full      Read full task output from disk (no buffer limit)
  tt peer read [id|name] --wait      Wait for peer to finish, then read
  tt peer last [id|name]             Read peer's last response
  tt peer last [id|name] --wait      Wait for peer to finish, then read response
  tt peer history [id|name]          Show peer's IPC conversation history

<id> can be: full session ID, short prefix (4+ chars), or name.
With one peer linked, "tt peer" commands auto-target it (no id needed).

Examples:
  tt ls                              See all terminals
  tt send sub-1 "npm test"           Run npm test in sub-1
  tt read sub-1 50                   Read last 50 lines (clean)
  tt read sub-1 --wait               Wait for sub-1 to finish processing
  tt notifications sub-1             Check notifications from sub-1
  tt tasks                            See delegated task progress
  tt peers                           See linked peers
  tt peer send "run the tests"       Send to linked peer — returns task_id
  tt task complete <task_id> --summary "..." --report report.md --changed "f1,f2" --unresolved none
                                     Close a task (ONLY way to mark it done — DONE: in notify is UI-only)
  tt task current                    Print task_id currently directed at this terminal
  tt task dir <task_id>              Get the output dir for the task (SUB writes reports here)
  tt task report <task_id>           MAIN reads the SUB's report
  tt task manifest <task_id>         MAIN reads the structured manifest.json for the task
  tt peer notify "message"           Send a UI notification to the linked terminal (no task state)
  tt peer read 50                    Read 50 lines from linked peer
  tt peer read --since-send          Read peer output since last task sent

Threat model:
  tboard trusts processes running INSIDE its own pty sessions (they receive TBOARD_TOKEN
  via env). Same-user processes OUTSIDE tboard pty sessions are considered untrusted
  in intent but able to read /proc/<pid>/environ on typical Linux — treat this as a
  shared-user machine caveat, not a hardened boundary. For multi-user / untrusted
  co-tenant use, run tboard on an isolated user account.
`);
}

function pad(str, width) {
  if (str.length >= width) return str.slice(0, width - 1) + ' ';
  return str + ' '.repeat(width - str.length);
}

main().catch((e) => {
  console.error(e.message);
  process.exit(1);
});
